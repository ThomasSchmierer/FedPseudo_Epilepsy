function [sid, centres] = cluster_Ts(Ts, tolSec)
Ts = double(Ts(:));
Ts = Ts(isfinite(Ts));
Ts_sorted = sort(Ts);
centres = [];
if isempty(Ts_sorted), sid = []; return; end
centres = Ts_sorted(1);
for i=2:numel(Ts_sorted)
    if abs(Ts_sorted(i) - centres(end)) <= tolSec
        centres(end) = 0.5*(centres(end) + Ts_sorted(i));
    else
        centres(end+1) = Ts_sorted(i); %#ok<AGROW>
    end
end
sid = nan(numel(Ts),1);
for i=1:numel(Ts)
    [~,k] = min(abs(centres - Ts(i)));
    if abs(centres(k) - Ts(i)) <= tolSec, sid(i) = k; end
end
sid = sid(:);
end

function idxPick = sample_negatives_relaxed(meta, idxPool, nTarget, useContig)
idxPool = idxPool(:);
if isempty(idxPool), idxPick = []; return; end
nTarget = min(nTarget, numel(idxPool));
if ~useContig
    idxPick = idxPool(randperm(numel(idxPool), nTarget));
    return;
end
if ~ismember('frameStartSec', meta.Properties.VariableNames)
    idxPick = idxPool(randperm(numel(idxPool), nTarget));
    return;
end
rec = string(meta.recordName);
fs  = double(meta.frameStartSec);
idxPick = [];
attempts = 0;
blockLen = max(50, min(600, round(nTarget/5)));
while numel(idxPick) < nTarget && attempts < 800
    attempts = attempts + 1;
    recs = unique(rec(idxPool));
    r = recs(randi(numel(recs)));
    idxR = idxPool(rec(idxPool)==r);
    [~,ord] = sort(fs(idxR));
    idxR = idxR(ord);
    if numel(idxR) < 5, continue; end
    L = min(blockLen, numel(idxR));
    s0 = randi(max(1, numel(idxR)-L+1));
    blk = idxR(s0:(s0+L-1));
    idxPick = unique([idxPick; blk(:)], 'stable'); %#ok<AGROW>
    if numel(idxPick) > nTarget, idxPick = idxPick(1:nTarget); end
end
if numel(idxPick) < nTarget
    rest = setdiff(idxPool, idxPick, 'stable');
    if ~isempty(rest)
        need = nTarget - numel(idxPick);
        take = rest(randperm(numel(rest), min(need, numel(rest))));
        idxPick = unique([idxPick; take(:)], 'stable'); %#ok<AGROW>
        if numel(idxPick) > nTarget, idxPick = idxPick(1:nTarget); end
    end
end
end
